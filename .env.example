# ===============================
# 🔗 URLs permitidas en CORS
# ===============================
# URLs del frontend que pueden conectarse al backend
# Separadas por comas (sin espacios)
# Ejemplo: http://localhost:5500,http://127.0.0.1:5500,https://mi-frontend.com
FRONTEND_URLS=http://localhost:5500,http://127.0.0.1:5500
